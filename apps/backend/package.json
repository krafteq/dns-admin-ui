{
  "name": "@dns-admin/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:bundle": "node esbuild.config.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@dns-admin/shared": "workspace:*",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.1.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "express": "^4.19.2",
    "jose": "^5.4.1",
    "openid-client": "^6.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "drizzle-kit": "^0.31.9",
    "esbuild": ">=0.25.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  }
}
